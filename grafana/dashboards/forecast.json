    {
      "id": 33,
      "type": "stat",
      "title": "RMSE Forecast 24h",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgres"
      },
      "gridPos": {
        "x": 20,
        "y": 26,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 3,
