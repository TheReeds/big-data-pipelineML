          "rawQuery": true,
          "format": "table",
          "refId": "A",
          "rawSql": "SELECT\n  TO_CHAR(forecast_time, 'HH24:MI') AS \"Hora\",\n  ROUND(api_temp::numeric, 1)  AS \"API (°C)\",\n  ROUND(pred_temp::numeric, 2) AS \"GBT (°C)\",\n  ROUND(error_abs::numeric, 2) AS error_abs\nFROM weather_forecast\nORDER BY forecast_time ASC LIMIT 6"
