      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres"
          },
          "rawSql": "\nSELECT ROUND(100.0*(lr.rmse - gbt.rmse)/lr.rmse, 1) AS mejora_pct\nFROM\n  (SELECT rmse FROM model_metrics WHERE model_name='LinearRegression' ORDER BY trained_at DESC LIMIT 1) lr,\n  (SELECT rmse FROM model_metrics WHERE model_name='GBTRegressor'     ORDER BY trained_at DESC LIMIT 1) gbt\n",
